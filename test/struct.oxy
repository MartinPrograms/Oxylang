@extern @symbol("sqrtf") fn sqrtf(x: f32) -> f32;
@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;
@extern @symbol("calloc") fn calloc(size: u64) -> ptr<u8>;

struct Vector2 {
	x: f32;
	y: f32;
}

struct NestedTest {
	vec: Vector2;
	value: i32;
}

struct NestedNestedTest {
	nested: ptr<NestedTest>;
	name: ptr<u8>; // null terminated string
}

struct NestedNestedNestedTest {
    nested: NestedNestedTest;
    description: ptr<u8>; // null terminated string
}

fn length(this: Vector2) -> f32 {
	return sqrtf(this.x * this.x + this.y * this.y);
}

fn distance(this: Vector2, other: Vector2) -> f32 {
	let dx = this.x - other.x;
	let dy = this.y - other.y;
	return sqrtf(dx * dx + dy * dy);
}

fn print_vector(this: Vector2) {
	printf("Vector2(x: %f, y: %f)\n", cast<f64>(this.x), cast<f64>(this.y));
}

@entry 
fn main() -> u8 {
	let v1 = Vector2 { x: 3.0f, y: 4.0f };
    let v2 = Vector2 { x: 6.0f, y: 8.0f };

    print_vector(v1);
    print_vector(v2);

    printf("Length of v1: %f\n", cast<f64>(length(v1)));
    printf("Length of v2: %f\n", cast<f64>(length(v2)));
    printf("Distance between v1 and v2: %f\n", cast<f64>(distance(v1, v2)));

    let sizeofVector2: u64 = sizeof<Vector2>;
    let sizeofNestedTest: u64 = sizeof<NestedTest>;
    let sizeofNestedNestedTest: u64 = sizeof<NestedNestedTest>;

    printf("Size of Vector2: %lu bytes\n", sizeofVector2);
    printf("Size of NestedTest: %lu bytes\n", sizeofNestedTest);
    printf("Size of NestedNestedTest: %lu bytes\n", sizeofNestedNestedTest);

    let nestedTestInstance = NestedTest { vec: v1, value: 42 };
    let nestedNestedTestInstance = NestedNestedTest { nested: addr(nestedTestInstance), name: "NestingTesting" };

    printf("NestedNestedTest name: %s\n", nestedNestedTestInstance.name);
    printf("NestedNestedTest nested: %p\n", (nestedNestedTestInstance.nested));
    printf("NestedTest value: %d\n", deref(nestedNestedTestInstance.nested).value);

    // let nestedNestedNestedTestInstance = NestedNestedNestedTest { nested: nestedNestedTestInstance, description: "This is a nested nested nested test." };
    // printf("NestedNestedNestedTest description: %s\n", nestedNestedNestedTestInstance.description);
    // let nested = deref(nestedNestedNestedTestInstance.nested.nested);
    // printf("NestedNestedNestedTest nested nested value: %d\n", nested.value);
    // print_vector(nested.vec);

	return 0u8;
}
