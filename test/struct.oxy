@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;
@extern @symbol("malloc") fn malloc(size: i64) -> ptr<u8>;

struct Point {
    x: f64;
    y: f64;
}

struct Node {
    point: Point;
    next: ptr<Node>;
}

fn create_list() -> ptr<Node> {
    let head: ptr<Node> = cast<ptr<Node>>(malloc(sizeof<Node>));
    head->next = null;
    return head;
}

fn add_point_to_linked_list(head: ptr<Node>, point: Point) {
    let new_node: ptr<Node> = cast<ptr<Node>>(malloc(sizeof<Node>));
    new_node->point = point;
    new_node->next = head->next;
    head->next = new_node;
}

fn iterate_linked_list(head: ptr<Node>, callback: fn(ptr<Point>)) {
    let current: ptr<Node> = head->next;
    while (current != null) {
        callback(addr(current->point));
        current = current->next;
    }
}

fn print_point(point: ptr<Point>) {
    printf("Point(x: %f, y: %f)\n", point->x, point->y);
}

@entry
fn main() -> u8 {
    printf("Testing linked list of points...\n");
    let list: ptr<Node> = create_list();
    printf("Created list at address: %p\n", list);
    for (let i = 0; i < 5; i = i + 1) {
        let point: Point = Point { x: cast<f64>(i), y: cast<f64>(i * 2) };
        add_point_to_linked_list(list, point);
    }
    iterate_linked_list(list, print_point);

    return 0u8;
}