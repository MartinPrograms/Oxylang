@extern @symbol("InitWindow") fn InitWindow(width: i32, height: i32, title: ptr<u8>) -> void;
@extern @symbol("SetTargetFPS") fn SetTargetFPS(fps: i32) -> void;
@extern @symbol("WindowShouldClose") fn WindowShouldClose() -> u8; // bool (u8)
@extern @symbol("CloseWindow") fn CloseWindow() -> void;
@extern @symbol("BeginDrawing") fn BeginDrawing() -> void;
@extern @symbol("EndDrawing") fn EndDrawing() -> void;
@extern @symbol("ClearBackground") fn ClearBackground(color: i32) -> void;
@extern @symbol("DrawText") fn DrawText(text: ptr<u8>, x: i32, y: i32, fontSize: i32, color: i32) -> void;
@extern @symbol("GetFPS") fn GetFPS() -> i32;
@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;
@extern @symbol("IsKeyDown") fn IsKeyDown(key: i32) -> u8; // bool (u8)

@entry
fn main() -> u8 {
    let width: i32 = 800;
    let height: i32 = 450;
    let title: ptr<u8> = "Hello World";

    InitWindow(width, height, title);
    SetTargetFPS(0); // Unlimited FPS

    let x = 400;
    let y = 225;
    let counter = 0;

    let key_a = 65; // ASCII code for 'A'
    let key_d = 68; // ASCII code for 'D'
    let key_w = 87; // ASCII code for 'W'
    let key_s = 83; // ASCII code for 'S'

    while (true) {
        if (WindowShouldClose() != 0) {
            break;
        }

        BeginDrawing();
        ClearBackground(0xFF000000); // opaque black
        DrawText("Hello, Raylib!", x, y, 20, 0xFFFFFFFF); // white

        let is_key_a_down = IsKeyDown(key_a) && 1; // Convert to 0 or 1
        let is_key_d_down = IsKeyDown(key_d) && 1;
        let is_key_w_down = IsKeyDown(key_w) && 1;
        let is_key_s_down = IsKeyDown(key_s) && 1;

        if (is_key_a_down != 0) {
            x = x - 5;
        }

        if (is_key_d_down != 0) {
            x = x + 5;
        }

        if (is_key_w_down != 0) {
            y = y - 5;
        }

        if (is_key_s_down != 0) {
            y = y + 5;
        }

        EndDrawing();
    }

    CloseWindow();
    return 0;
}