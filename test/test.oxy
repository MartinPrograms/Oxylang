let a = 0;

@extern @symbol("puts") fn puts(s: ptr<u8>) -> i32;

fn test_bitwise_ambiguity() -> void {
    let a: i32 = 0xFF;
    let b: i32 = 0x0F;
    let c: i32 = 0xF0;

    // let x = a & b | c;       // ERROR: ambiguous, needs (a & b) | c
    // let y = a | b ^ c;       // ERROR: ambiguous, needs (a | b) ^ c
    // let z = a << 2 & b;      // ERROR: ambiguous, needs (a << 2) & b

    let ok1 = (a & b) | c;   // OK
    let ok2 = a | (b ^ c);   // OK
}

fn test_array_bounds() -> void {
    let arr: array<i32, 4>;

    arr[3] = 10;    // OK  - last valid index
    arr[4] = 20;    // ERROR: index 4 out of bounds for array<i32, 4>
    arr[-1] = 30;   // ERROR: negative index

    let i: i32 = 2;
    arr[i] = 99;    // OK (runtime, bounds check inserted by compiler per spec)
}

fn test_null_usage() -> void {
    let a: i32 = null;      // ERROR: null is ptr<void>, not i32
    let b: f32 = null;      // ERROR: null is ptr<void>, not f32
    let c: u8 = null;       // ERROR: null is ptr<void>, not u8

    let ok1: ptr<i32> = cast<ptr<i32>>(null);       // OK
    let ok2: ptr<void> = null;      // OK
}

@entry
fn main() -> u8 {
    let s = "Hello, World!\0";
    puts(s);
    a = 42;
    return 0u8;
}