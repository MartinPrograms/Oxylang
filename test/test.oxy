@entry
fn main() -> u8 {
    let r5 = 10;
    r5 = 5;
    if (r5 > 0) {
        let r6 = 20;
        r6 = 15;
    }
    // let r7 = r6 would cause out of scope error, as r6 is only defined in the if block.

    for (let i = 0; i < 5; i = i + 1) {
        let r9 = i * 2;
        r9 = r9 + 1;
    }

    return cast<u8>(test_function());
}

struct test_struct {
    a: i32;
    b: i32;
}

fn test_function() -> i32 {
    let r10 = 100;
    let s: test_struct;
    r10 = r10 - 50;
    return r10;
}