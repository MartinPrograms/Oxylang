// Simple raylib game
@extern @symbol("InitWindow") fn init_window(width: i32, height: i32, title: ptr<u8>);
@extern @symbol("SetTargetFPS") fn set_target_fps(fps: i32);
@extern @symbol("WindowShouldClose") fn window_should_close() -> u8;
@extern @symbol("BeginDrawing") fn begin_drawing();
@extern @symbol("DrawRectangle") fn draw_rectangle(x: i32, y: i32, width: i32, height: i32, color: i32);
@extern @symbol("ClearBackground") fn clear_background(color: i32);
@extern @symbol("DrawText") fn draw_text(text: ptr<u8>, x: i32, y: i32, font_size: i32, color: i32);
@extern @symbol("EndDrawing") fn end_drawing();
@extern @symbol("IsKeyDown") fn is_key_down(key: i32) -> u8;
@extern @symbol("CloseWindow") fn close_window();
@extern @symbol("calloc") fn calloc(size: u64) -> ptr<u8>;
@extern @symbol("sprintf") fn sprintf(buffer: ptr<u8>, format: ptr<u8>, ...) -> i32;
@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;
@extern @symbol("rand") fn rand() -> i32;

let WHITE: i32 = 0xFFFFFFFF;
let BLACK: i32 = 0xFF000000;
let RED: i32 = 0xFF0000FF;
let GREEN: i32 = 0xFF00FF00;
let BLUE: i32 = 0xFFFF0000;
let YELLOW: i32 = 0xFFFFFF00;
let TITLE: ptr<u8> = "Hello, Raylib from Oxy!";
let SCORE_TEXT: ptr<u8> = "%d - %d";

let PADDLE_HEIGHT: i32 = 100;
let PADDLE_WIDTH: i32 = 20;
let BALL_SIZE: i32 = 20;
let PADDLE_SPEED: i32 = 5;

let KEY_W: i32 = 87;
let KEY_S: i32 = 83;
let KEY_UP: i32 = 265;
let KEY_DOWN: i32 = 264;

let SCORE_TO_WIN: i32 = 10;

fn handle_movement(left_paddle_y: ptr<i32>, right_paddle_y: ptr<i32>) {
    let PADDLE_MAX_Y: i32 = 600 - PADDLE_HEIGHT;
    let PADDLE_MIN_Y: i32 = 0;

    let is_w_down: u8 = is_key_down(KEY_W) && 1u8;
    let is_s_down: u8 = is_key_down(KEY_S) && 1u8;
    let is_up_down: u8 = is_key_down(KEY_UP) && 1u8;
    let is_down_down: u8 = is_key_down(KEY_DOWN) && 1u8;
    let current_left_paddle_y: i32 = deref(left_paddle_y);
    let current_right_paddle_y: i32 = deref(right_paddle_y);

    // The oxy lang uses addr and deref to work with pointers
    if (is_w_down > 0u8) {
        deref(left_paddle_y) = deref(left_paddle_y) - PADDLE_SPEED;
    }
    if (is_s_down > 0u8) {
        deref(left_paddle_y) = deref(left_paddle_y) + PADDLE_SPEED;
    }
    if (is_up_down > 0u8) {
        deref(right_paddle_y) = deref(right_paddle_y) - PADDLE_SPEED;
    }
    if (is_down_down > 0u8) {
        deref(right_paddle_y) = deref(right_paddle_y) + PADDLE_SPEED;
    }

    if (deref(left_paddle_y) < PADDLE_MIN_Y) {
        deref(left_paddle_y) = PADDLE_MIN_Y;
    }

    if (deref(left_paddle_y) > PADDLE_MAX_Y) {
        deref(left_paddle_y) = PADDLE_MAX_Y;
    }

    if (deref(right_paddle_y) < PADDLE_MIN_Y) {
        deref(right_paddle_y) = PADDLE_MIN_Y;
    }

    if (deref(right_paddle_y) > PADDLE_MAX_Y) {
        deref(right_paddle_y) = PADDLE_MAX_Y;
    }
}

fn random_direction() -> i32 {
    if (rand() % 2 == 0) {
        return 1;
    } else {
        return -1;
    }

    return 0;
}

fn handle_ball_movement(ball_x: ptr<i32>,
                        ball_y: ptr<i32>,
                        ball_speed_x: ptr<i32>,
                        ball_speed_y: ptr<i32>,
                        ball_direction_x: ptr<i32>,
                        ball_direction_y: ptr<i32>,
                        left_paddle_y: ptr<i32>,
                        right_paddle_y: ptr<i32>,
                        left_score: ptr<i32>,
                        right_score: ptr<i32>
                    ) {
    let BALL_MAX_X: i32 = 800 - BALL_SIZE;
    let BALL_MIN_X: i32 = 0;
    let BALL_MAX_Y: i32 = 600 - BALL_SIZE;
    let BALL_MIN_Y: i32 = 0;

    let current_ball_x: i32 = deref(ball_x);
    let current_ball_y: i32 = deref(ball_y);

    let current_ball_speed_x: i32 = deref(ball_speed_x);
    let current_ball_speed_y: i32 = deref(ball_speed_y);

    let current_ball_direction_x: i32 = deref(ball_direction_x);
    let current_ball_direction_y: i32 = deref(ball_direction_y);

    let current_left_paddle_y: i32 = deref(left_paddle_y);
    let current_right_paddle_y: i32 = deref(right_paddle_y);

    // Move the ball
    deref(ball_x) = deref(ball_x) + (deref(ball_speed_x) * deref(ball_direction_x));
    deref(ball_y) = deref(ball_y) + (deref(ball_speed_y) * deref(ball_direction_y));

    // Check for collision with top and bottom walls
    if (deref(ball_y) <= BALL_MIN_Y || deref(ball_y) >= BALL_MAX_Y) {
        deref(ball_direction_y) = deref(ball_direction_y) * -1;
    }

    // Check for collision with left paddle
    if (deref(ball_x) <= 10 + PADDLE_WIDTH && deref(ball_x) >= 10 && deref(ball_y) + BALL_SIZE >= current_left_paddle_y && deref(ball_y) <= current_left_paddle_y + PADDLE_HEIGHT) {
        deref(ball_direction_x) = deref(ball_direction_x) * -1;
    }

    // Check for collision with right paddle
    if (deref(ball_x) >= 770 - BALL_SIZE && deref(ball_x) <= 770 && deref(ball_y) + BALL_SIZE >= current_right_paddle_y && deref(ball_y) <= current_right_paddle_y + PADDLE_HEIGHT) {
        deref(ball_direction_x) = deref(ball_direction_x) * -1;
    }

    if (deref(ball_x) < BALL_MIN_X) {
        deref(right_score) = deref(right_score) + 1;
        deref(ball_x) = 400;
        deref(ball_y) = 300;
        deref(ball_direction_x) = random_direction();
        deref(ball_direction_y) = random_direction();
    }

    if (deref(ball_x) > BALL_MAX_X) {
        deref(left_score) = deref(left_score) + 1;
        deref(ball_x) = 400;
        deref(ball_y) = 300;
        deref(ball_direction_x) = random_direction();
        deref(ball_direction_y) = random_direction();
    }
}

@entry
fn main() -> u8 {
    let score_buffer = cast<ptr<u8>>(calloc(128));

    init_window(800, 600, TITLE);

    let ball_x: i32 = 400;
    let ball_y: i32 = 300;
    let ball_speed_x: i32 = 4;
    let ball_speed_y: i32 = 4;
    let ball_direction_x: i32 = random_direction();
    let ball_direction_y: i32 = random_direction();

    let left_paddle_y: i32 = 250;
    let right_paddle_y: i32 = 250;

    let left_score: i32 = 0;
    let right_score: i32 = 0;

    set_target_fps(60);

    let running: u8 = 1u8;
    while (running > 0u8) {
        if (window_should_close() > 0u8) {
            running = 0u8;
        }

        handle_movement(addr(left_paddle_y), addr(right_paddle_y));
        handle_ball_movement(addr(ball_x), addr(ball_y), addr(ball_speed_x), addr(ball_speed_y), addr(ball_direction_x), addr(ball_direction_y), addr(left_paddle_y), addr(right_paddle_y), addr(left_score), addr(right_score));

        begin_drawing();

        clear_background(BLACK);

        draw_rectangle(10, left_paddle_y, PADDLE_WIDTH, PADDLE_HEIGHT, WHITE);
        draw_rectangle(770, right_paddle_y, PADDLE_WIDTH, PADDLE_HEIGHT, WHITE);

        draw_rectangle(ball_x, ball_y, BALL_SIZE, BALL_SIZE, WHITE);

        let score_text_length: i32 = sprintf(score_buffer, SCORE_TEXT, left_score, right_score);
        draw_text(score_buffer, 350, 10, 20, YELLOW);

        end_drawing();
    }

    close_window();

    return 0u8;
}