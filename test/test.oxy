// ─── TYPE INFERENCE & LITERAL SUFFIXES ────────────────────────────────────────
fn test_literal_inference() -> void {
    let a = 0;          // i32
    let b = 0.0;        // f64
    let c = 0.0f;       // f32
    let d = 0u8;        // u8
    let e = 0xFFi16;   // i16 (hex with suffix)
    let f = 0b1010u64;  // u64 (binary with suffix)
    let g = true;       // u8 (per spec: bool handled as u8)
    let h = false;      // u8

    // let bad1 = 999999999999; // ERROR? - i32 overflow, spec says default is i32
    // let bad2 = 0.0 + 0.0f;  // ERROR: f64 + f32, no implicit promotion
}


// ─── NO IMPLICIT NUMERIC PROMOTION ────────────────────────────────────────────

fn test_no_implicit_promotion() -> void {
    let a: i32 = 10;
    let b: i64 = 20;
    let c: f32 = 1.0f;
    let d: f64 = 2.0;

    // let bad1: i64 = a;           // ERROR: i32 not assignable to i64 without cast
    // let bad2 = a + b;            // ERROR: i32 + i64, no implicit promotion
    // let bad3 = c + d;            // ERROR: f32 + f64
    // let bad4: f64 = c;           // ERROR: f32 not assignable to f64

    let ok1: i64 = cast<i64>(a);
    let ok2 = cast<i64>(a) + b;
    let ok3 = cast<f64>(c) + d;
}


