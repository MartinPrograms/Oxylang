@extern @symbol("InitWindow") fn init_window(width: i32, height: i32, title: ptr<u8>);
@extern @symbol("SetTargetFPS") fn set_target_fps(fps: i32);
@extern @symbol("WindowShouldClose") fn window_should_close() -> u8;
@extern @symbol("BeginDrawing") fn begin_drawing();
@extern @symbol("DrawRectangle") fn draw_rectangle(x: i32, y: i32, width: i32, height: i32, color: i32);
@extern @symbol("ClearBackground") fn clear_background(color: i32);
@extern @symbol("DrawText") fn draw_text(text: ptr<u8>, x: i32, y: i32, font_size: i32, color: i32);
@extern @symbol("EndDrawing") fn end_drawing();
@extern @symbol("IsKeyDown") fn is_key_down(key: i32) -> u8;
@extern @symbol("CloseWindow") fn close_window();
@extern @symbol("calloc") fn calloc(size: u64) -> ptr<u8>;
@extern @symbol("sprintf") fn sprintf(buffer: ptr<u8>, format: ptr<u8>, ...) -> i32;
@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;
@extern @symbol("rand") fn rand() -> i32;

let WHITE: i32 = 0xFFFFFFFF;
let BLACK: i32 = 0xFF000000;
let RED: i32 = 0xFF0000FF;
let GREEN: i32 = 0xFF00FF00;
let BLUE: i32 = 0xFFFF0000;
let YELLOW: i32 = 0xFFFFFF00;

let KEY_W: i32 = 87;
let KEY_S: i32 = 83;
let KEY_UP: i32 = 265;
let KEY_DOWN: i32 = 264;

struct Paddle {
    x: i32;
    y: i32;
    width: i32;
    height: i32;
}

struct Ball {
    x: i32;
    y: i32;
    radius: i32;
    speed_x: i32;
    speed_y: i32;
}

struct GameState {
    PaddleLeft: Paddle;
    PaddleRight: Paddle;
    Ball: Ball;
    ScoreLeft: i32;
    ScoreRight: i32;
}

fn draw_paddle(p: Paddle) {
    draw_rectangle(p.x, p.y, p.width, p.height, 0xFFFFFFFF); // White color
}

fn handle_input(left: ptr<Paddle>, right: ptr<Paddle>) {
    let is_key_w_down: u8 = is_key_down(KEY_W) && 1u8;
    let is_key_s_down: u8 = is_key_down(KEY_S) && 1u8;
    let is_key_up_down: u8 = is_key_down(KEY_UP) && 1u8;
    let is_key_down_down: u8 = is_key_down(KEY_DOWN) && 1u8;

    if (is_key_w_down > 0u8) {
        deref(left).y = deref(left).y - 5;
    }

    if (is_key_s_down > 0u8) {
        deref(left).y = deref(left).y + 5;
    }

    if (is_key_up_down > 0u8) {
        deref(right).y = deref(right).y - 5;
    }

    if (is_key_down_down > 0u8) {
        deref(right).y = deref(right).y + 5;
    }

    if (deref(left).y < 0) {
        deref(left).y = 0;
    }

    if (deref(left).y + deref(left).height > 600) {
        deref(left).y = 600 - deref(left).height;
    }

    if (deref(right).y < 0) {
        deref(right).y = 0;
    }

    if (deref(right).y + deref(right).height > 600) {
        deref(right).y = 600 - deref(right).height;
    }
}

fn random_direction() -> i32 {
    let r: i32 = rand() % 2;
    if (r == 0) {
        return -1;
    } else {
        return 1;
    }

    return 0;
}

fn reset_ball(ball: ptr<Ball>) {
    deref(ball).x = 400;
    deref(ball).y = 300;
    deref(ball).speed_x = 5 * random_direction();
    deref(ball).speed_y = 5 * random_direction();
}

fn handle_ball(paddle_left: ptr<Paddle>, paddle_right: ptr<Paddle>, ball: ptr<Ball>, score_left: ptr<i32>, score_right: ptr<i32>) {
    deref(ball).x = deref(ball).x + deref(ball).speed_x;
    deref(ball).y = deref(ball).y + deref(ball).speed_y;

    // Check collision with top and bottom walls
    if (deref(ball).y - deref(ball).radius <= 0 || deref(ball).y + deref(ball).radius >= 600) {
        deref(ball).speed_y = -deref(ball).speed_y;
    }

    // Check collision with left paddle
    if (deref(ball).x - deref(ball).radius <= deref(paddle_left).x + deref(paddle_left).width &&
        deref(ball).y >= deref(paddle_left).y &&
        deref(ball).y <= deref(paddle_left).y + deref(paddle_left).height) {
        deref(ball).speed_x = -deref(ball).speed_x;
    }

    // Check collision with right paddle
    if (deref(ball).x + deref(ball).radius >= deref(paddle_right).x &&
        deref(ball).y >= deref(paddle_right).y &&
        deref(ball).y <= deref(paddle_right).y + deref(paddle_right).height) {
        deref(ball).speed_x = -deref(ball).speed_x;
    }

    // Check for scoring
    if (deref(ball).x < 0) {
        deref(score_right) = deref(score_right) + 1;
        reset_ball(ball);
    } else if (deref(ball).x > 800) {
        deref(score_left) = deref(score_left) + 1;
        reset_ball(ball);
    }
}

@entry
fn main() -> u8 {
    let game_state = GameState {
        PaddleLeft: Paddle { x: 50, y: 200, width: 10, height: 100 },
        PaddleRight: Paddle { x: 740, y: 200, width: 10, height: 100 },
        Ball: Ball { x: 400, y: 300, radius: 10, speed_x: 5, speed_y: 5 },
        ScoreLeft: 0,
        ScoreRight: 0
    };

    let paddleRight: Paddle = game_state.PaddleRight;
    let paddleLeft: Paddle = game_state.PaddleLeft;

    init_window(800, 600, "Pong");
    set_target_fps(60);

    let running: u8 = 1u8;
    while (running > 0u8) {
        if (window_should_close() && 1u8 > 0u8) {
            running = 0u8;
        }

        handle_input(addr(game_state.PaddleLeft), addr(game_state.PaddleRight));
        handle_ball(addr(game_state.PaddleLeft), addr(game_state.PaddleRight), addr(game_state.Ball), addr(game_state.ScoreLeft), addr(game_state.ScoreRight));

        begin_drawing();

        draw_paddle(game_state.PaddleLeft);
        draw_paddle(game_state.PaddleRight);
        draw_rectangle(game_state.Ball.x - game_state.Ball.radius, game_state.Ball.y - game_state.Ball.radius, game_state.Ball.radius * 2, game_state.Ball.radius * 2, 0xFFFFFFFF); // Draw ball

        clear_background(0x000000); // Black background

        end_drawing();
    }

    return 0u8;
}