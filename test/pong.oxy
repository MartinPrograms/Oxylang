@extern @symbol("InitWindow")        fn init_window(width: i32, height: i32, title: ptr<u8>);
@extern @symbol("SetTargetFPS")      fn set_target_fps(fps: i32);
@extern @symbol("WindowShouldClose") fn window_should_close() -> u8;
@extern @symbol("BeginDrawing")      fn begin_drawing();
@extern @symbol("DrawRectangle")     fn draw_rectangle(x: i32, y: i32, width: i32, height: i32, color: u32);
@extern @symbol("ClearBackground")   fn clear_background(color: u32);
@extern @symbol("DrawText")          fn draw_text(text: ptr<u8>, x: i32, y: i32, font_size: i32, color: u32);
@extern @symbol("EndDrawing")        fn end_drawing();
@extern @symbol("IsKeyDown")         fn is_key_down(key: i32) -> u8;
@extern @symbol("CloseWindow")       fn close_window();
@extern @symbol("sprintf")           fn sprintf(buffer: ptr<u8>, format: ptr<u8>, ...) -> i32;
@extern @symbol("rand")              fn rand() -> i32;
@extern @symbol("calloc")            fn calloc(size: u64) -> ptr<u8>;

// Region: Colors
// Raylib Color on little-endian: (a<<24) | (b<<16) | (g<<8) | r
let WHITE:  u32 = 0xFFFFFFFFu32;
let BLACK:  u32 = 0xFF000000u32;
let RED:    u32 = 0xFF0000FFu32;
let GREEN:  u32 = 0xFF00FF00u32;
let BLUE:   u32 = 0xFFFF0000u32;
let YELLOW: u32 = 0xFF00FFFFu32;

// Region: Constants
let WIDTH:  i32 = 800;
let HEIGHT: i32 = 600;

let KEY_W:     i32 = 87;
let KEY_S:     i32 = 83;
let KEY_UP:    i32 = 265;
let KEY_DOWN:  i32 = 264;
let KEY_SPACE: i32 = 32;

struct Paddle {
    x: i32;
    y: i32;
    width: i32;
    height: i32;
}

struct Ball {
    x: i32;
    y: i32;
    radius: i32;
    speed_x: f32;
    speed_y: f32;
}

struct GameState {
    left_paddle:  Paddle;
    right_paddle: Paddle;
    ball:         Ball;
    left_score:   i32;
    right_score:  i32;
    won:          u8;
}

fn draw_paddle(paddle: ptr<Paddle>) {
    draw_rectangle(paddle->x, paddle->y, paddle->width, paddle->height, WHITE);
}

fn draw_ball(ball: ptr<Ball>) {
    draw_rectangle(ball->x - ball->radius, ball->y - ball->radius, ball->radius * 2, ball->radius * 2, WHITE);
}

fn random_speed() -> f32 {
    let speed: f32 = cast<f32>(rand() % 4 + 2);
    if (rand() % 2 == 0) {
        return speed;
    } else {
        return -speed;
    }

    return 0.0f;
}

fn reset_ball(ball: ptr<Ball>) {
    ball->x = 400;
    ball->y = 300;
    ball->speed_x = random_speed();
    ball->speed_y = random_speed();
}

fn paddle_movement(paddle: ptr<Paddle>, up_key: i32, down_key: i32) {
    if (is_key_down(up_key) > 0u8) {
        paddle->y = paddle->y - 3;
    }
    if (is_key_down(down_key) > 0u8) {
        paddle->y = paddle->y + 3;
    }
    if (paddle->y < 0) {
        paddle->y = 0;
    }
    if (paddle->y + paddle->height > HEIGHT) {
        paddle->y = HEIGHT - paddle->height;
    }
}

fn ball_movement(ball: ptr<Ball>, left_paddle: ptr<Paddle>, right_paddle: ptr<Paddle>, game: ptr<GameState>) {
    ball->x = cast<i32>(cast<f32>(ball->x) + ball->speed_x);
    ball->y = cast<i32>(cast<f32>(ball->y) + ball->speed_y);

    if (ball->y - ball->radius < 0) {
        ball->y = ball->radius;
        ball->speed_y = -ball->speed_y;
    }

    if (ball->y + ball->radius > HEIGHT) {
        ball->y = HEIGHT - ball->radius;
        ball->speed_y = -ball->speed_y;
    }

    if ((ball->x - ball->radius < left_paddle->x + left_paddle->width) &&
        (ball->y > left_paddle->y) &&
        (ball->y < left_paddle->y + left_paddle->height)) {
        ball->speed_x = -ball->speed_x * 1.04f;
        ball->speed_y = ball->speed_y * 1.04f;
        if (ball->speed_x < 0.0f) {
            ball->speed_x = -ball->speed_x;
        }
    }

    if ((ball->x + ball->radius > right_paddle->x) &&
        (ball->y > right_paddle->y) &&
        (ball->y < right_paddle->y + right_paddle->height)) {
        ball->speed_x = -ball->speed_x * 1.04f;
        ball->speed_y = ball->speed_y * 1.04f;
        if (ball->speed_x > 0.0f) {
            ball->speed_x = -ball->speed_x;
        }
    }

    if (ball->x - ball->radius < 0) {
        game->right_score = game->right_score + 1;
        reset_ball(ball);
    }

    if (ball->x + ball->radius > WIDTH) {
        game->left_score = game->left_score + 1;
        reset_ball(ball);
    }
}

fn update_game(game: ptr<GameState>) {
    paddle_movement(addr(game->left_paddle), KEY_W, KEY_S);
    paddle_movement(addr(game->right_paddle), KEY_UP, KEY_DOWN);
    ball_movement(addr(game->ball), addr(game->left_paddle), addr(game->right_paddle), game);

    if (game->left_score >= 10) {
        game->won = 1u8;
    }

    if (game->right_score >= 10) {
        game->won = 2u8;
    }
}

@entry
fn main() -> u8 {
    init_window(WIDTH, HEIGHT, "Pong in Oxy!");
    set_target_fps(120);

    let game: GameState = GameState {
        left_paddle:  Paddle { x: 50,  y: 250, width: 20, height: 100 },
        right_paddle: Paddle { x: 730, y: 250, width: 20, height: 100 },
        ball:         Ball { x: 400, y: 300, radius: 10, speed_x: 2.0f, speed_y: 2.0f },
        left_score:  0,
        right_score: 0,
        won:         0u8
    };

    let running: u8 = 1u8;
    let fmt: ptr<u8> = "%d - %d";
    let buf: ptr<u8> = cast<ptr<u8>>(calloc(128));

    while (running > 0u8) {
        if (window_should_close() > 0u8) {
            running = 0u8;
        }

        if (game.won > 0u8) {
            begin_drawing();
            clear_background(BLACK);
            if (game.won == 1u8) {
                draw_text("Left Player Wins!", WIDTH / 2 - 100, HEIGHT / 2 - 20, 30, GREEN);
            } else {
                draw_text("Right Player Wins!", WIDTH / 2 - 100, HEIGHT / 2 - 20, 30, GREEN);
            }
            end_drawing();

            if (is_key_down(KEY_SPACE) > 0u8) {
                game.left_score = 0;
                game.right_score = 0;
                game.won = 0u8;
                reset_ball(addr(game.ball));
                game.left_paddle.y = 250;
                game.right_paddle.y = 250;
            }
        } else {
            update_game(addr(game));

            begin_drawing();
            clear_background(BLACK);

            draw_paddle(addr(game.left_paddle));
            draw_paddle(addr(game.right_paddle));
            draw_ball(addr(game.ball));

            sprintf(buf, fmt, game.left_score, game.right_score);
            draw_text(buf, WIDTH / 2 - 50, 20, 20, YELLOW);

            end_drawing();
        }
    }

    close_window();
    return 0u8;
}