@extern @symbol("InitWindow")      fn InitWindow(width: i32, height: i32, title: ptr<u8>) -> void;
@extern @symbol("SetTargetFPS")    fn SetTargetFPS(fps: i32) -> void;
@extern @symbol("WindowShouldClose") fn WindowShouldClose() -> u8;
@extern @symbol("CloseWindow")     fn CloseWindow() -> void;
@extern @symbol("BeginDrawing")    fn BeginDrawing() -> void;
@extern @symbol("EndDrawing")      fn EndDrawing() -> void;
@extern @symbol("ClearBackground") fn ClearBackground(color: i32) -> void;
@extern @symbol("DrawRectangle")   fn DrawRectangle(x: i32, y: i32, w: i32, h: i32, color: i32) -> void;
@extern @symbol("DrawText")        fn DrawText(text: ptr<u8>, x: i32, y: i32, fontSize: i32, color: i32) -> void;
@extern @symbol("IsKeyDown")       fn IsKeyDown(key: i32) -> u8;
@extern @symbol("TextFormat")      fn TextFormat(fmt: ptr<u8>, ...) -> ptr<u8>;
@extern @symbol("MeasureText")     fn MeasureText(text: ptr<u8>, fontSize: i32) -> i32;

@entry
fn main() -> u8 {
    let W: i32 = 800;
    let H: i32 = 600;

    InitWindow(W, H, "PONG — Oxylang");
    SetTargetFPS(60);

    // Layout constants
    let PADDLE_W: i32    = 14;
    let PADDLE_H: i32    = 90;
    let PADDLE_SPEED: i32 = 6;
    let BALL_SIZE: i32   = 14;
    let SCORE_TO_WIN: i32 = 7;

    // Colors: 0xAABBGGRR  (little-endian RGBA – matches raylib Color struct layout)
    let BLACK:    i32 = 0xFF000000;
    let WHITE:    i32 = 0xFFFFFFFF;  // i32 bit-pattern -1, matches user's own example
    let DGRAY:    i32 = 0xFF333333;
    let MGRAY:    i32 = 0xFF666666;
    let LGRAY:    i32 = 0xFF999999;
    let P1COLOR:  i32 = 0xFF4080FF;  // blue-ish  (r=0xFF,g=0x80,b=0x40)
    let P2COLOR:  i32 = 0xFF40FF80;  // green-ish (r=0x80,g=0xFF,b=0x40)

    // Key codes (Raylib)
    let KEY_W:     i32 = 87;
    let KEY_S:     i32 = 83;
    let KEY_UP:    i32 = 265;
    let KEY_DOWN:  i32 = 264;
    let KEY_SPACE: i32 = 32;

    // Game state
    let p1y: i32 = 255;   // left paddle Y
    let p2y: i32 = 255;   // right paddle Y

    let bx:  i32 = 393;   // ball position
    let by:  i32 = 293;
    let bvx: i32 = 5;     // ball velocity
    let bvy: i32 = 3;

    let s1:  i32 = 0;
    let s2:  i32 = 0;

    // won: 0 = playing, 1 = P1 won, 2 = P2 won
    let won: i32 = 0;

    while (true) {
        if (WindowShouldClose() != 0) {
            break;
        }

        let isKeyDownW = IsKeyDown(KEY_W) && 1;
        let isKeyDownS = IsKeyDown(KEY_S) && 1;
        let isKeyDownUp = IsKeyDown(KEY_UP) && 1;
        let isKeyDownDown = IsKeyDown(KEY_DOWN) && 1;

        if (isKeyDownW != 0) {
            p1y = p1y - PADDLE_SPEED;
        }
        if (isKeyDownS != 0) {
            p1y = p1y + PADDLE_SPEED;
        }
        if (isKeyDownUp != 0){
            p2y = p2y - PADDLE_SPEED;
        }
        if (isKeyDownDown != 0) {
            p2y = p2y + PADDLE_SPEED;
        }

        BeginDrawing();
        ClearBackground(BLACK);

        // Centre dashed line
        let cy: i32 = 10;
        while (cy < H) {
            DrawRectangle(397, cy, 6, 24, MGRAY);
            cy = cy + 44;
        }

        // Score progress bars (top strip)
        let si: i32 = 0;
        while (si < s1) {
            DrawRectangle(20 + si * 22, 4, 18, 10, P1COLOR);
            si = si + 1;
        }
        si = 0;
        while (si < s2) {
            DrawRectangle(638 - si * 22, 4, 18, 10, P2COLOR);
            si = si + 1;
        }

        // Numeric scores
        DrawText(TextFormat("%d", s1), 295, 18, 64, P1COLOR);
        DrawText(":",                  392, 22, 56, MGRAY);
        DrawText(TextFormat("%d", s2), 462, 18, 64, P2COLOR);

        // Paddles
        DrawRectangle(20,  p1y, PADDLE_W, PADDLE_H, P1COLOR);
        DrawRectangle(766, p2y, PADDLE_W, PADDLE_H, P2COLOR);

        // Paddle glow strip (1px inner highlight)
        DrawRectangle(21,  p1y + 2, 2, PADDLE_H - 4, WHITE);
        DrawRectangle(779, p2y + 2, 2, PADDLE_H - 4, WHITE);

        // Ball
        DrawRectangle(bx,     by,     BALL_SIZE,     BALL_SIZE,     WHITE);
        DrawRectangle(bx + 2, by + 2, BALL_SIZE - 4, BALL_SIZE - 4, LGRAY);

        // Controls footer
        DrawText("W / S",         25, 575, 16, MGRAY);
        DrawText("UP / DOWN",    695, 575, 16, MGRAY);
        DrawText("FIRST TO 7",   340, 575, 16, LGRAY);

        EndDrawing();
    }

    CloseWindow();
    return 0;
}
