@extern @symbol("sqrt") fn sqrt(value: f64) -> f64;

struct Vector4 {
    x: f64;
    y: f64;
    z: f64;
    w: f64;
}

fn callback() {
    let v = Vector4 { x: 1.0, y: 2.0, z: 3.0, w: 4.0 };
    let length = sqrt(v.x * v.x + v.y * v.y + v.z * v.z + v.w * v.w);
    printf("Vector length: %f\n", length);
}


@entry
fn main() -> u8 {
    let black: g::Color = g::Color { r: 0u8, g: 0u8, b: 0u8, a: 255u8 };

    g::run_loop(black, callback);

    return 0u8;
}