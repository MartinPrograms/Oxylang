// import "testing.oxy" as test;
@extern @symbol("printf") fn printf(format: ptr<u8>, ...) -> i32;

// test
/*
This is a test program to demonstrate the use of printf in Oxy.
*/

struct X {
	x: i32;
	y: ptr<ptr<ptr<ptr<i32>>>>;
	z: array<ptr<fn (i32, ...) -> i32>, 5>;
}

struct Vector3<T> {
	X: T;
	Y: T;
	Z: T;
}

struct Transform {
	position: Vector3<f32>;
	rotation: Vector3<f32>;
	scale: Vector3<f32>;
}

fn CreateVector3<T>(X: T, Y: T, Z: T) -> Vector3<T> {
	return Vector3<T> { X: X, Y: Y, Z: Z };
}

fn CreateIdentityTransform() -> Transform {
	return Transform {
		position: CreateVector3<f32>(0.0f, 0.0f, 0.0f),
		rotation: CreateVector3<f32>(0.0f, 0.0f, 0.0f),
		scale: CreateVector3<f32>(1.0f, 1.0f, 1.0f),
	};
}

// Move point by reference (skips a copy of the point)
fn MovePoint<T>(point: ptr<Vector3<T>>, Vector: Vector3<T>) -> void {
	point->X += Vector.X;
	point->Y += Vector.Y;
	point->Z += Vector.Z;
}

@entry 
fn main () -> u8 {
    	let a: u8 = 5u8;
    	let b: u8 = 10u8;
    	let c: u8 = a + b;
    	printf("The sum of %d and %d is %d\n", a, b, c);

	let d: i32 = printf("This is a function return test: %d", c);
	let f = CreateVector3<f64>(1.0, 2.0f, 3.0);
	printf("Vector3: X = %f, Y = %f, Z = %f\n", f.X, f.Y, f.Z);

	f.X = 4.0f;
	printf("Updated Vector3: X = %f, Y = %f, Z = %f\n", f.X, f.Y, f.Z);


	return c;
}


